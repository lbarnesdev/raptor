# ----- Godot generated -----
.godot/
*.uid
*.translation
export_presets.cfg

# Import cache (regenerated on open)
.import/

# Godot 3 remnant guard
.mono/

# ----- .NET / C# build output -----
[Bb]in/
[Oo]bj/
*.user
*.suo
.vs/
*.DotSettings.user

# NuGet
.nuget/
packages/
*.nupkg

# ----- OS noise -----
.DS_Store
Thumbs.db
desktop.ini
*~

# ----- Editor artifacts -----
*.swp
*.swo
*.orig

# ----- Art pipeline -----
tools/art_gen/__pycache__/
tools/art_gen/*.pyc
tools/art_gen/art_manifest.json

# ----- Test results -----
TestResults/
*.trx
coverage/

# ----- Export builds -----
builds/
*.exe
*.x86_64
*.pck
*.apk
*.aab
*.ipa

# ============================================================
# Explicitly keep tracked
# ============================================================
!assets/sprites/**
!assets/audio/**
!assets/data/**
