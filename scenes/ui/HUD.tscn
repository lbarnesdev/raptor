[gd_scene load_steps=2 format=3 uid="uid://raptor0hud01"]

; ── External resources ────────────────────────────────────────────────────────
[ext_resource type="Script" path="res://src/UI/HUD.cs" id="1_hud"]

; ── Scene tree ────────────────────────────────────────────────────────────────
; Design resolution: 1920 × 1080.
; All offsets are screen-space pixels from the top-left corner (0, 0).
;
; Layout:
;   Top-left cluster  (x 20–180, y 16–98):
;     ShieldIcon  40×40  at (20,16)
;     LifeIcon1   30×22  at (70,20)  LifeIcon2 (108,20)  LifeIcon3 (146,20)
;     MissileIcon1…6  20×28  at (20,70) spaced 28px apart
;
;   Top-right:
;     ScoreLabel  label  at (1300,16) → (1900,50)  right-aligned
;
;   Bottom:
;     BossHealthBar Control  at (80,1000) → (1840,1060)  hidden until boss
;       Seg1 (0→573) Seg2 (580→1153) Seg3 (1160→1760)

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1_hud")

; ── Score + multiplier ────────────────────────────────────────────────────────
[node name="ScoreLabel" type="Label" parent="."]
offset_left = 1300.0
offset_top = 16.0
offset_right = 1900.0
offset_bottom = 50.0
text = "SCORE: 000000  ×1"
horizontal_alignment = 2
theme_override_font_sizes/font_size = 24

