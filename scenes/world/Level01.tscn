; ── Scene tree ────────────────────────────────────────────────────────────────
; Slice 1 — camera + player.
; Slice 2 — ProjectilePool + PlasmaBolt wired.
; Slice 3 — one hard-placed enemy + score HUD.
; Slice 4 — scrolling camera, LevelDirector + EnemyContainer, wave JSON.
; Slice 5 — Boss.tscn wired to LevelDirector; spawns at t=162s.
;
; Required node paths (referenced by GetNode in C# _Ready() methods):
;   /root/Level01/ScrollCamera          ← Player.cs
;   /root/Level01/ProjectileContainer   ← PlasmaWeapon.cs, MissileWeapon.cs
;   /root/Level01/EnemyContainer        ← LevelDirector.cs
;   /root/Level01/Entities/Player       ← GameManager.cs (TODO comment)

[node name="Level01" type="Node2D"]

; ── Camera ─────────────────────────────────────────────────────────────────────
; Centred at screen midpoint. ScrollCamera.cs calls MakeCurrent() in _Ready().
; Scrolls rightward at 120 px/s; stops when LevelDirector fires StopScroll at t=160s.
[node name="ScrollCamera" type="Camera2D" parent="."]
position = Vector2(960, 540)
script = ExtResource("1_scrollcam")

; ── Player ─────────────────────────────────────────────────────────────────────
[node name="Entities" type="Node2D" parent="."]

[node name="Player" parent="Entities" instance=ExtResource("2_player")]
position = Vector2(300, 540)

; ── Enemy container ─────────────────────────────────────────────────────────────
; LevelDirector.cs adds dynamically-spawned enemies here (ADR-004).
; Keeping enemies in their own container makes DespawnAllEnemies fast: iterate
; children rather than searching a mixed-content Entities node.
[node name="EnemyContainer" type="Node2D" parent="."]

; ── Projectile container ────────────────────────────────────────────────────────
; Required by PlasmaWeapon._Ready() and MissileWeapon._Ready() at scene load.
; All live projectiles are reparented here at spawn (ADR-003).
[node name="ProjectileContainer" type="Node2D" parent="."]

; ── Effects container ───────────────────────────────────────────────────────────
; Explosion VFX, SporeCloud instances. Empty until Slice 5.
[node name="EffectsContainer" type="Node2D" parent="."]

; ── HUD ────────────────────────────────────────────────────────────────────────
; Instanced from HUD.tscn (TICKET-704).  Owns score label, shield icon,
; life icons, missile ammo row, and boss health bar — all driven by EventBus.
[node name="HUD" parent="." instance=ExtResource("5_hud")]

; ── Projectile pool ─────────────────────────────────────────────────────────────
; NOT an autoload — lifetime is scoped to the level scene.
; ProjectileScenes array is indexed by ProjectileType enum value:
;   [0] PlasmaBolt  ← wired (Slice 2)
;   [1..7]          ← assigned in later slices; pool logs warnings for nulls
[node name="ProjectilePool" type="Node" parent="."]
script = ExtResource("3_pool")
; ProjectileScenes indexed by ProjectileType enum:
;   [0] PlasmaBolt         [1] Missile (Slice 9)  [2] PlasmaBlob (Slice 8)
;   [3] CrystalSpine (S8)  [4] OrganicSpore (S8)  [5] ConstitutionBlast
;   [6] FoxBroadcastPulse (Slice 6)                [7] HateShuriken (Slice 6)
ProjectileScenes = Array[PackedScene]([ExtResource("4_plasmabolt"), null, null, null, null, ExtResource("10_cblast"), ExtResource("11_foxpulse"), ExtResource("12_shuriken")])

; ── Checkpoints ─────────────────────────────────────────────────────────────────
; Three Marker2D nodes define respawn positions.  Indices match the JSON events:
;   0 = Checkpoint_Act1  (level start  — x=300,   never fired from JSON)
;   1 = Checkpoint_Act2  (t=80s        — x=9600,  scroll speed 120 px/s)
;   2 = Checkpoint_Boss  (t=160s       — x=19200, just before boss arena)
[node name="Checkpoints" type="Node2D" parent="."]

[node name="Checkpoint_Act1" type="Marker2D" parent="Checkpoints"]
position = Vector2(300, 540)

[node name="Checkpoint_Act2" type="Marker2D" parent="Checkpoints"]
position = Vector2(9600, 540)

[node name="Checkpoint_Boss" type="Marker2D" parent="Checkpoints"]
position = Vector2(19200, 540)

; CheckpointManager is NOT an autoload — lifetime is scoped to the level scene.
; Checkpoints array wired to the three Marker2D nodes above.
[node name="CheckpointManager" type="Node" parent="."]
script = ExtResource("13_checkpointmgr")
Checkpoints = Array[NodePath]([NodePath("../Checkpoints/Checkpoint_Act1"), NodePath("../Checkpoints/Checkpoint_Act2"), NodePath("../Checkpoints/Checkpoint_Boss")])

; ── Level Director ──────────────────────────────────────────────────────────────
; Reads res://data/level_01_waves.json and ticks the event timeline each frame.
; BasicEnemyScene must be assigned so SpawnWave can instantiate enemies.
[node name="LevelDirector" type="Node" parent="."]
script = ExtResource("7_leveldirector")
BasicEnemyScene = ExtResource("6_basicenemy")
BossScene = ExtResource("8_boss")
