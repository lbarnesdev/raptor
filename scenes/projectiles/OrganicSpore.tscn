; scenes/projectiles/OrganicSpore.tscn
; ─────────────────────────────────────────────────────────────────────────────
; Harbinger Turret projectile. Large, slow, coral-orange blob. PRD F-223.
;
; Velocity is NOT fixed — HarbingerTurret computes the aimed direction at fire
; time and scales by OrganicSpore.NominalSpeed (140 px/s).
;
; Collision (collision_layer=32 = EnemyProjectile, layer 6):
;   collision_mask = 6  (PlayerShield=4 + Player=2)
;   ShieldArea intercepts via area_entered before Player body_entered (ADR-005).
; ─────────────────────────────────────────────────────────────────────────────
[gd_scene format=3 uid="uid://raptor0organicspore01"]

[ext_resource type="Script" path="res://src/Projectiles/OrganicSpore.cs" id="1_organicspore"]

; Collision shape — circle 22 px radius.
[sub_resource type="CircleShape2D" id="1_shape"]
radius = 22.0

[node name="OrganicSpore" type="Area2D"]
collision_layer = 32
collision_mask = 6
script = ExtResource("1_organicspore")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("1_shape")

; Placeholder visual — large coral-orange blob, octagon ~22 px radius.
; 8-point polygon at 45° intervals.
[node name="PlaceholderShape" type="Polygon2D" parent="."]
polygon = PackedVector2Array(22, 0, 15.56, 15.56, 0, 22, -15.56, 15.56, -22, 0, -15.56, -15.56, 0, -22, 15.56, -15.56)
color = Color(1.0, 0.5, 0.2, 0.95)
