; ── Collision shape ───────────────────────────────────────────────────────────
; Circle matches the ~28 px visual radius with a slightly tighter hitbox.
[sub_resource type="CircleShape2D" id="1_cblastshape"]
radius = 18.0

; ── Scene tree ────────────────────────────────────────────────────────────────
; Collision layers:
;   ConstitutionBlast — layer 6 (EnemyProjectile) = 2^5 = 32
;                        mask:  Player(2) + PlayerShield(4) = 6
;
; Note: mask bit 4 (PlayerShield=4) is included so the ShieldArea AreaEntered
; signal in ShieldController can also detect this projectile in Slice 7.
; BodyEntered on this Area2D fires only for Player CharacterBody2D (mask bit 2).

[node name="ConstitutionBlast" type="Area2D"]
collision_layer = 32
collision_mask = 6
script = ExtResource("1_cblast")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("1_cblastshape")

