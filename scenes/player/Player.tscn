[gd_scene load_steps=12 format=3 uid="uid://raptor0player01"]

; ── External scripts ──────────────────────────────────────────────────────────
[ext_resource type="Script" path="res://src/Player/Player.cs" id="1_player"]
[ext_resource type="Script" path="res://src/Player/ShieldController.cs" id="2_shield"]
[ext_resource type="Script" path="res://src/Player/PlasmaWeapon.cs" id="3_plasma"]
[ext_resource type="Script" path="res://src/Player/MissileWeapon.cs" id="4_missile"]

; ── Sprite textures ───────────────────────────────────────────────────────────
[ext_resource type="Texture2D" path="res://assets/sprites/player/player_idle.png" id="5_idletex"]
[ext_resource type="Texture2D" path="res://assets/sprites/player/player_thrust.png" id="6_thrusttex"]

; ── SpriteFrames ─────────────────────────────────────────────────────────────
; Two animations: "idle" (looping, 5 fps) and "thrust" (looping, 8 fps).
; Player.cs does not call sprite.Play() directly — the AnimatedSprite2D
; autoplays "idle" on load.  Add C# code to switch to "thrust" on input if desired.
[sub_resource type="SpriteFrames" id="5_frames"]
animations = [{
"frames": [{
"duration": 1.0,
"texture": ExtResource("5_idletex")
}],
"loop": true,
"name": &"idle",
"speed": 5.0
}, {
"frames": [{
"duration": 1.0,
"texture": ExtResource("6_thrusttex")
}],
"loop": true,
"name": &"thrust",
"speed": 8.0
}]

; ── Animations ───────────────────────────────────────────────────────────────
; hurt_flash: flickers AnimatedSprite2D modulate red/transparent over 0.5 s (3 pulses)
; then restores to normal white.
[sub_resource type="Animation" id="3_hurtanim"]
resource_name = "hurt_flash"
length = 0.5
loop_mode = 0
tracks/0/type = "value"
tracks/0/imported = false
tracks/0/enabled = true
tracks/0/path = NodePath("../AnimatedSprite2D:modulate")
tracks/0/interp = 1
tracks/0/loop_wrap = false
tracks/0/keys = {
"times": PackedFloat32Array(0.0, 0.083, 0.166, 0.25, 0.333, 0.416, 0.5),
"transitions": PackedFloat32Array(1, 1, 1, 1, 1, 1, 1),
"update": 0,
"values": [Color(1, 0.3, 0.3, 0.0), Color(1, 0.3, 0.3, 1.0), Color(1, 0.3, 0.3, 0.0), Color(1, 0.3, 0.3, 1.0), Color(1, 0.3, 0.3, 0.0), Color(1, 0.3, 0.3, 1.0), Color(1, 1, 1, 1)]
}

[sub_resource type="AnimationLibrary" id="4_animlib"]
_data = {
"hurt_flash": SubResource("3_hurtanim")
}

; ── Collision shapes ──────────────────────────────────────────────────────────
; Body: tight rectangle around the F-22 fuselage (80×32 px at 128×64 sprite size)
[sub_resource type="RectangleShape2D" id="1_bodyshape"]
size = Vector2(80, 32)

; Shield: circle slightly larger than the ship hull
[sub_resource type="CircleShape2D" id="2_shieldshape"]
radius = 50.0

; ── Scene tree ────────────────────────────────────────────────────────────────
; See arch doc Section 3.2 for the full Player.tscn hierarchy.
;
; Collision layers (project.godot layer names):
;   Player body  — layer 2 (bit 1 = 2),  mask: World(1) + EnemyProjectile(32) + Hazard(128) = 161
;   ShieldArea   — layer 3 (bit 2 = 4),  mask: EnemyProjectile(32) = 32

[node name="Player" type="CharacterBody2D"]
collision_layer = 2
collision_mask = 161
script = ExtResource("1_player")

; ── Body collision ─────────────────────────────────────────────────────────────
[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("1_bodyshape")

; ── Sprite ────────────────────────────────────────────────────────────────────
; AnimatedSprite2D with real SpriteFrames (Slice 11).  Autoplays "idle".
; HurtFlash animation targets this node's modulate for the red-flash hit feedback.
[node name="AnimatedSprite2D" type="AnimatedSprite2D" parent="."]
sprite_frames = SubResource("5_frames")
animation = &"idle"
autoplay = "idle"

; ── Shield ─────────────────────────────────────────────────────────────────────
[node name="ShieldController" type="Node" parent="."]
script = ExtResource("2_shield")

[node name="ShieldArea" type="Area2D" parent="ShieldController"]
collision_layer = 4
collision_mask = 32

[node name="CollisionShape2D" type="CollisionShape2D" parent="ShieldController/ShieldArea"]
shape = SubResource("2_shieldshape")

; ShieldSprite — Polygon2D octagon approximating the CircleShape2D (radius 50).
; Starts at the Active colour (blue, 0.8 alpha); ShieldController.OnShieldStateChanged
; drives Modulate at runtime.  No texture needed — pure vertex colour.
; 8 vertices at radius 48, angles 0°, 45°, 90° … 315°.
[node name="ShieldSprite" type="Polygon2D" parent="ShieldController/ShieldArea"]
polygon = PackedVector2Array(48, 0, 33.94, 33.94, 0, 48, -33.94, 33.94, -48, 0, -33.94, -33.94, 0, -48, 33.94, -33.94)
color = Color(1, 1, 1, 1)
modulate = Color(0.3, 0.7, 1.0, 0.8)

; ── Plasma weapon ──────────────────────────────────────────────────────────────
[node name="PlasmaWeapon" type="Node2D" parent="."]
script = ExtResource("3_plasma")

; MuzzlePoint sits at the nose of the ship (x=40 → right edge of ~80 px sprite)
[node name="MuzzlePoint" type="Marker2D" parent="PlasmaWeapon"]
position = Vector2(40, 0)

; ── Missile weapon ─────────────────────────────────────────────────────────────
[node name="MissileWeapon" type="Node2D" parent="."]
script = ExtResource("4_missile")

[node name="MuzzlePoint" type="Marker2D" parent="MissileWeapon"]
position = Vector2(40, 0)

; ── Hurt flash ─────────────────────────────────────────────────────────────────
; Flickers AnimatedSprite2D modulate red/transparent on hit, returns to white.
; Player.Die() calls: GetNode<AnimationPlayer>("HurtFlash").Play("hurt_flash")
[node name="HurtFlash" type="AnimationPlayer" parent="."]
libraries = {
"": SubResource("4_animlib")
}
