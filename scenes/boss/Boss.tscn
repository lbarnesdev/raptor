; ── Scene tree ────────────────────────────────────────────────────────────────
;
; Boss root (Node2D) — Boss.cs handles all phase logic.
; All movement is scripted via Tween / AnimationPlayer (ADR-001).
;
; Collision layers:
;   WeakPoint Area2Ds — layer 7 (BossWeakPoint)  = 2^6 = 64
;                        mask 5 (PlayerProjectile) = 2^4 = 16
;
; All WeakPoint nodes start with monitoring=false and visible=false.
; Boss.cs calls WeakPoint.SetActive(true) for the active phase only.
;
; Placeholder visuals (replace with AnimatedSprite2D in Slice 11):
;   BodySprite     — large grey rectangle (200 × 360 px)
;   WeakPointSprite — small gold square (40 × 40 px), shown when active

[node name="Boss" type="Node2D"]
script = ExtResource("1_boss")

; ── Main body placeholder ─────────────────────────────────────────────────────
; Replace with AnimatedSprite2D + Demagogue sprite sheet in Slice 11.
[node name="BodySprite" type="Polygon2D" parent="."]
polygon = PackedVector2Array(-100, -180, 100, -180, 100, 180, -100, 180)
color = Color(0.55, 0.55, 0.6, 1)

; ── Phase 1 — Tiny Hand ───────────────────────────────────────────────────────
; Hand cycles open (3 s, weak point exposed) / closed (2 s, invulnerable).
; Phase1Controller (Slice 6) drives the animation cycle.
[node name="TinyHandNode" type="Node2D" parent="."]
position = Vector2(80, 50)

[node name="WeakPoint_P1" type="Area2D" parent="TinyHandNode"]
collision_layer = 64
collision_mask = 16
monitoring = false
visible = false
script = ExtResource("2_weakpoint")
PhaseIndex = 1

[node name="CollisionShape2D" type="CollisionShape2D" parent="TinyHandNode/WeakPoint_P1"]
shape = SubResource("1_wp1shape")

; Placeholder: pulsing gold square visible when Phase 1 is active.
; Replace with Constitution sprite wrapped in alien tentacle (Slice 11).
[node name="WeakPointSprite" type="Polygon2D" parent="TinyHandNode/WeakPoint_P1"]
polygon = PackedVector2Array(-20, -20, 20, -20, 20, 20, -20, 20)
color = Color(1, 0.85, 0, 0.9)

; ── Phase 2 — Toupee Hatch ────────────────────────────────────────────────────
; Hatch cycles open (4 s) / closed (3 s). Fox News logo is the weak point.
; Phase2Controller (Slice 6) drives the cycle + bonus wave spawning.
